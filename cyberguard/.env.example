CYBERGUARD_API_URL=http://localhost:8000
CYBERGUARD_API_TOKEN=replace-me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=cyberguard
POSTGRES_USER=cyberguard
POSTGRES_PASSWORD=cyberguard
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cyberguard123
REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
ELASTICSEARCH_URL=http://localhost:9200

# ── Pipeline settings ────────────────────────────────────────────────────────
# Database (defaults to SQLite for local dev when unset)
CYBERGUARD_DB_URL=sqlite:///./cyberguard-dev.db
# For PostgreSQL: postgresql+psycopg2://user:password@localhost:5432/cyberguard

# LLM provider — 'openai-compatible' (default) or 'anthropic'
CYBERGUARD_LLM_PROVIDER=openai-compatible
CYBERGUARD_LLM_MODEL=replace-me
CYBERGUARD_LLM_API_KEY=replace-me
# Base URL for openai-compatible endpoints (e.g. self-hosted, KiConnect)
CYBERGUARD_LLM_BASE_URL=

# GitHub token — optional, raises API rate limit from 60 to 5,000 req/hour
# Used by Stage 4 exploit enrichment to search for PoC repositories
CYBERGUARD_GITHUB_TOKEN=
